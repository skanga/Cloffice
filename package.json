{
  "name": "relay",
  "version": "2026.3.24",
  "private": false,
  "license": "MIT",
  "description": "Electron desktop cowork client for OpenClaw backends",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "predev": "kill-port 5173",
    "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"vite\" \"wait-on dist-electron/electron/main.js http-get://localhost:5173/ && electron .\"",
    "dev:e2e": "concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"vite\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test:file-safety && npm run test:local-actions",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test:file-safety": "node scripts/file-safety-smoke.mjs",
    "test:local-actions": "npm run build:electron && node scripts/local-actions-smoke.mjs",
    "test:e2e": "kill-port 5173 18789 && concurrently -k -s first \"wait-on http-get://localhost:5173/ && npm run test:e2e:runner\" \"npm run test:e2e:mock-gateway\" \"npm run dev:e2e\"",
    "test:e2e:runner": "playwright test -c playwright.electron.config.ts --workers=1",
    "test:e2e:headed": "kill-port 5173 18789 && concurrently -k -s first \"wait-on http-get://localhost:5173/ && npm run test:e2e:runner:headed\" \"npm run test:e2e:mock-gateway\" \"npm run dev:e2e\"",
    "test:e2e:runner:headed": "playwright test -c playwright.electron.config.ts --headed --workers=1",
    "test:e2e:debug": "kill-port 5173 18789 && concurrently -k -s first \"wait-on http-get://localhost:5173/ && npm run test:e2e:runner:debug\" \"npm run test:e2e:mock-gateway\" \"npm run dev:e2e\"",
    "test:e2e:runner:debug": "playwright test -c playwright.electron.config.ts --debug --workers=1",
    "test:e2e:real": "kill-port 5173 && concurrently -k -s first \"wait-on http-get://localhost:5173/ && npm run test:e2e:runner:real\" \"npm run dev:e2e\"",
    "test:e2e:runner:real": "set RELAY_E2E_REAL_GATEWAY=1&& playwright test -c playwright.electron.config.ts --workers=1",
    "test:e2e:real:headed": "kill-port 5173 && concurrently -k -s first \"wait-on http-get://localhost:5173/ && npm run test:e2e:runner:real:headed\" \"npm run dev:e2e\"",
    "test:e2e:runner:real:headed": "set RELAY_E2E_REAL_GATEWAY=1&& playwright test -c playwright.electron.config.ts --headed --workers=1",
    "test:e2e:mock-gateway": "node tests/e2e/mock-gateway.mjs",
    "preview": "vite preview",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.relay.app",
    "productName": "Relay",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@noble/ed25519": "^3.0.0",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5",
    "ws": "^8.18.3"
  }
}
